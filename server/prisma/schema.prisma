generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum promotion_status {
  PENDING
  APPROVED
  REJECTED
}

enum article_status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum notification_type {
  NEW_ARTICLE
}

model role {
  role_id            String              @id @default(uuid())
  name               String              @unique
  description        String?
  users              user[]
  promotion_requests promotion_request[]

  @@map("roles")
}

model user {
  user_id           String             @id @default(uuid())
  role_id           String
  role              role               @relation(fields: [role_id], references: [role_id])
  email             String             @unique
  fullname          String
  password          String
  salt              String
  status            Boolean            @default(true)
  bio               String?
  twitter           String?
  department        String?
  avatar            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  refresh_tokens        refresh_token[]
  promotion_requests    promotion_request[]
  articles              article[]
  password_reset_tokens password_reset_token[]
  followers             follow[]           @relation("UserFollowing")
  following             follow[]           @relation("UserFollowers")
  notifications         notification[]

  @@map("users")
}

model refresh_token {
  id        String   @id @default(uuid())
  token     String   @unique
  user_id   String
  user      user     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  expiresAt DateTime

  @@map("refresh_tokens")
}

model promotion_request {
  promotion_request_id String           @id @default(uuid())
  user_id              String
  user                 user             @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  role_id              String
  role                 role             @relation(fields: [role_id], references: [role_id])
  reason               String
  status               promotion_status @default(PENDING)
  reviewed_at          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@map("promotion_requests")
}

model article {
  article_id   String         @id @default(uuid())
  author_id    String
  author       user           @relation(fields: [author_id], references: [user_id], onDelete: Cascade)
  title        String
  slug         String         @unique
  content      String
  cover_image  String?
  status       article_status @default(DRAFT)
  published_at DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("articles")
}

model password_reset_token {
  id        String   @id @default(uuid())
  token     String   @unique
  user_id   String
  user      user     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model follow {
  follow_id    String   @id @default(uuid())
  follower_id  String
  following_id String
  follower     user     @relation("UserFollowers", fields: [follower_id], references: [user_id], onDelete: Cascade)
  following    user     @relation("UserFollowing", fields: [following_id], references: [user_id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([follower_id, following_id])
  @@map("follows")
}

model notification {
  notification_id String            @id @default(uuid())
  user_id         String
  user            user              @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  type            notification_type
  title           String
  body            String
  article_id      String?
  article_slug    String?
  read            Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@map("notifications")
}
